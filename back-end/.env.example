DATABASE_PROVIDER=postgres

# MongoDB is kept only for archive/export scripts.
MONGO_URL=
MONGO_USERNAME=<your-username>
MONGO_PASSWORD=<your-password>
MONGO_CLUSTER_HOST=<your-cluster>.mongodb.net
MONGO_DATABASE=test

SERVER_HOSTNAME=localhost
SERVER_PORT=3000
SERVER_CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200
SOCKET_CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200
PUBLIC_FRONTEND_URL=http://localhost:4200
SERVER_TOKEN_EXPIRETIME=3600
SERVER_TOKEN_ISSUER=husaria
SERVER_REFRESH_TOKEN_SECRET=<change-me>
SERVER_TOKEN_SECRET=<change-me>
JUDGE_TOKEN_SECRET=<change-me>
AUTH_SESSION_SECRET=<change-me>
AUTH_COOKIE_NAME=husaria_session
AUTH_SESSION_DAYS=14
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=

# Required for PostgreSQL runtime.
POSTGRES_URL=postgresql://husaria:husaria_dev_password@localhost:5432/husaria
