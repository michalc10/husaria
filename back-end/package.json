{
  "name": "my-app",
  "version": "1.0.0",
  "description": "My Node.js app",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "dev": "prisma generate && nodemon src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "db:report": "ts-node src/scripts/mongoDatabaseReport.ts",
    "db:export:mongo": "ts-node src/scripts/exportMongoData.ts",
    "db:migrate:postgres:dry-run": "ts-node src/scripts/importMongoBackupToPostgres.ts --dry-run",
    "db:migrate:postgres:repair-dry-run": "ts-node src/scripts/importMongoBackupToPostgres.ts --dry-run --repair-orphans",
    "db:migrate:postgres": "ts-node src/scripts/importMongoBackupToPostgres.ts",
    "db:migrate:postgres:repair": "ts-node src/scripts/importMongoBackupToPostgres.ts --repair-orphans",
    "db:normalize:battles:dry-run": "ts-node src/scripts/normalizeBattles.ts --dry-run",
    "db:normalize:battles": "ts-node src/scripts/normalizeBattles.ts",
    "user:create-admin": "prisma generate && ts-node src/scripts/createAdminUser.ts",
    "test": "ts-node src/tests/battleParser.test.ts"
  },
  "keywords": [
    "node",
    "express",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "mongoose": "^9.6.3",
    "morgan": "^1.10.1",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.4",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
