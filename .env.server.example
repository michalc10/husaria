COMPOSE_PROJECT_NAME=husaria

# Public URL visible in the browser. For HTTPS hosting use https://your-domain.pl
PUBLIC_FRONTEND_URL=http://localhost
SERVER_CORS_ORIGIN=http://localhost
SOCKET_CORS_ORIGIN=http://localhost
FRONTEND_API_BASE_URL=
HTTP_PORT=80

# PostgreSQL
POSTGRES_DB=husaria
POSTGRES_USER=husaria
POSTGRES_PASSWORD=change_me_to_a_long_random_password
POSTGRES_PORT=5432

# Backend security
AUTH_SESSION_SECRET=change_me_to_a_long_random_session_secret
JUDGE_TOKEN_SECRET=change_me_to_a_long_random_judge_secret
SERVER_TOKEN_SECRET=
SERVER_REFRESH_TOKEN_SECRET=
AUTH_COOKIE_NAME=husaria_session
AUTH_SESSION_DAYS=14
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# Set to false only when migrations are handled by a separate deployment step.
RUN_PRISMA_MIGRATIONS=true
